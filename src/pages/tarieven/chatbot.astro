---
import Base from "../../layouts/Base.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import CTA from "../../components/CTA.astro";
---

<Base
  title="Tarieven AI Chatbot"
  description="Tarieven voor een AI chatbot op je website. Van basis tot compleet met WhatsApp, agenda-integratie en spraakassistent."
>
  <Breadcrumb items={[
    { label: "Home", href: "/" },
    { label: "Tarieven", href: "/tarieven/" },
    { label: "Chatbot" },
  ]} />

  <section class="py-20">
    <div class="mx-auto max-w-5xl px-6">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl">
          AI Chatbot
        </h1>
        <p class="mt-6 text-lg text-gray-600 dark:text-gray-300">
          Een digitale medewerker die 24/7 klaarstaat. Beantwoordt vragen, plant afspraken
          en werkt ook via WhatsApp.
        </p>
        <a
          href="/diensten/chatbot/"
          class="mt-4 inline-flex items-center gap-1 text-sm text-primary-600 transition-colors hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300"
        >
          Meer over de chatbot
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>

      <div class="mt-16 grid gap-8 lg:grid-cols-3">
        <!-- Basis -->
        <div class="flex flex-col rounded-2xl border border-gray-200 bg-white p-8 dark:border-gray-700 dark:bg-gray-800">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
            Basis
          </h2>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            Website chatbot
          </p>
          <div class="mt-6">
            <span class="text-4xl font-bold text-gray-900 dark:text-white">&euro;99</span>
            <span class="text-gray-500 dark:text-gray-400">/maand</span>
          </div>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            excl. BTW &middot; maandelijks opzegbaar
          </p>

          <ul class="mt-8 flex-1 space-y-3 text-sm text-gray-600 dark:text-gray-300">
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Chatbot op je website
            </li>
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Getraind op jouw FAQ en diensten
            </li>
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Lead capture (e-mail, telefoon)
            </li>
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Notificaties bij nieuwe leads
            </li>
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Tot 500 gesprekken/maand
            </li>
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Maandelijkse aanpassingen inbegrepen
            </li>
          </ul>

          <div class="mt-6 rounded-lg bg-gray-50 p-3 text-sm text-gray-600 dark:bg-gray-700 dark:text-gray-300">
            <span class="font-medium text-gray-900 dark:text-white">Eenmalig:</span> &euro;250 setup
          </div>

          <a
            href="/contact/"
            class="mt-6 inline-flex w-full items-center justify-center rounded-lg border border-primary-600 px-6 py-3 text-sm font-semibold text-primary-600 transition-colors hover:bg-primary-50 dark:border-primary-400 dark:text-primary-400 dark:hover:bg-primary-900/20"
          >
            Basis aanvragen
          </a>
        </div>

        <!-- Plus (highlighted) -->
        <div class="relative flex flex-col rounded-2xl border-2 border-primary-600 bg-white p-8 shadow-lg dark:border-primary-400 dark:bg-gray-800">
          <div class="absolute -top-3 left-6 rounded-full bg-primary-600 px-3 py-0.5 text-xs font-semibold text-white dark:bg-primary-400 dark:text-gray-900">
            Meest gekozen
          </div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
            Plus
          </h2>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            Website + WhatsApp + agenda
          </p>
          <div class="mt-6">
            <span class="text-4xl font-bold text-gray-900 dark:text-white">&euro;199</span>
            <span class="text-gray-500 dark:text-gray-400">/maand</span>
          </div>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            excl. BTW &middot; maandelijks opzegbaar
          </p>

          <ul class="mt-8 flex-1 space-y-3 text-sm text-gray-600 dark:text-gray-300">
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <strong class="text-gray-900 dark:text-white">Alles van Basis, plus:</strong>
            </li>
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              WhatsApp Business integratie
            </li>
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Agenda-integratie (Google/Outlook)
            </li>
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Automatische afspraakbevestigingen
            </li>
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Tot 1.500 gesprekken/maand
            </li>
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Wekelijkse rapportage per e-mail
            </li>
          </ul>

          <div class="mt-6 rounded-lg bg-primary-50 p-3 text-sm text-primary-800 dark:bg-primary-900/30 dark:text-primary-200">
            <span class="font-medium">Eenmalig:</span> &euro;450 setup
          </div>

          <a
            href="/contact/"
            class="mt-6 inline-flex w-full items-center justify-center rounded-lg bg-primary-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-primary-700"
          >
            Plus aanvragen
          </a>
        </div>

        <!-- Compleet -->
        <div class="flex flex-col rounded-2xl border border-gray-200 bg-white p-8 dark:border-gray-700 dark:bg-gray-800">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
            Compleet
          </h2>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            Volledige AI-ondersteuning
          </p>
          <div class="mt-6">
            <span class="text-4xl font-bold text-gray-900 dark:text-white">&euro;349</span>
            <span class="text-gray-500 dark:text-gray-400">/maand</span>
          </div>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            excl. BTW &middot; maandelijks opzegbaar
          </p>

          <ul class="mt-8 flex-1 space-y-3 text-sm text-gray-600 dark:text-gray-300">
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <strong class="text-gray-900 dark:text-white">Alles van Plus, plus:</strong>
            </li>
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              AI Spraakassistent (telefoon)
            </li>
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Eenvoudig CRM-dashboard
            </li>
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Automatische opvolgmails
            </li>
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Review-aanvragen na afspraak
            </li>
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Onbeperkt gesprekken
            </li>
            <li class="flex items-start gap-2">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Prioriteit support
            </li>
          </ul>

          <div class="mt-6 rounded-lg bg-gray-50 p-3 text-sm text-gray-600 dark:bg-gray-700 dark:text-gray-300">
            <span class="font-medium text-gray-900 dark:text-white">Eenmalig:</span> &euro;750 setup
          </div>

          <a
            href="/contact/"
            class="mt-6 inline-flex w-full items-center justify-center rounded-lg border border-primary-600 px-6 py-3 text-sm font-semibold text-primary-600 transition-colors hover:bg-primary-50 dark:border-primary-400 dark:text-primary-400 dark:hover:bg-primary-900/20"
          >
            Compleet aanvragen
          </a>
        </div>
      </div>

      <!-- FAQ -->
      <div class="mx-auto mt-20 max-w-3xl">
        <h2 class="text-center text-2xl font-bold text-gray-900 dark:text-white">
          Veelgestelde vragen
        </h2>
        <dl class="mt-8 space-y-6">
          <div>
            <dt class="font-semibold text-gray-900 dark:text-white">Kan ik upgraden of downgraden?</dt>
            <dd class="mt-1 text-gray-600 dark:text-gray-300">
              Ja, je kunt elke maand wisselen van pakket. De wijziging gaat in op de volgende factuurdatum.
            </dd>
          </div>
          <div>
            <dt class="font-semibold text-gray-900 dark:text-white">Wat als ik meer gesprekken heb dan in mijn pakket zit?</dt>
            <dd class="mt-1 text-gray-600 dark:text-gray-300">
              We nemen contact op als je regelmatig over de limiet gaat. Je kunt dan upgraden of extra gesprekken bijkopen tegen &euro;0,10 per gesprek.
            </dd>
          </div>
          <div>
            <dt class="font-semibold text-gray-900 dark:text-white">Is er een minimale looptijd?</dt>
            <dd class="mt-1 text-gray-600 dark:text-gray-300">
              Nee, alle pakketten zijn maandelijks opzegbaar. De setup-kosten zijn eenmalig en worden niet terugbetaald bij opzegging.
            </dd>
          </div>
          <div>
            <dt class="font-semibold text-gray-900 dark:text-white">Wat kost de spraakassistent aan belminuten?</dt>
            <dd class="mt-1 text-gray-600 dark:text-gray-300">
              De eerste 100 belminuten per maand zitten inbegrepen in Compleet. Daarna &euro;0,15 per minuut.
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <CTA
    heading="Klaar om je chatbot te starten?"
    description="Plan een demo en zie binnen 15 minuten hoe het werkt voor jouw bedrijf."
    buttonText="Plan een demo"
  />
</Base>
