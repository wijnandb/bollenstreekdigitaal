---
import Base from "../../layouts/Base.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.date.toLocaleDateString("nl-NL", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const updatedDate = post.data.updated ? new Date(post.data.updated) : null;
const formattedUpdatedDate = updatedDate?.toLocaleDateString("nl-NL", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const isoDate = post.data.date.toISOString();
const isoUpdatedDate = updatedDate?.toISOString() || isoDate;
const postUrl = new URL(`/blog/${post.id}/`, Astro.site).href;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description,
  datePublished: isoDate,
  dateModified: isoUpdatedDate,
  author: {
    "@type": "Organization",
    name: "Bollenstreek Digitaal",
    url: "https://bollenstreekdigitaal.nl",
  },
  publisher: {
    "@type": "Organization",
    name: "Bollenstreek Digitaal",
    url: "https://bollenstreekdigitaal.nl",
  },
  mainEntityOfPage: postUrl,
  inLanguage: "nl",
};
---

<Base title={post.data.title} description={post.data.description} ogType="article" jsonLd={articleJsonLd}>
  <Breadcrumb items={[
    { label: "Home", href: "/" },
    { label: "Blog", href: "/blog/" },
    { label: post.data.title },
  ]} />

  <article class="py-12">
    <div class="mx-auto max-w-3xl px-6">
      <header>
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-gray-500 dark:text-gray-400">
          <time datetime={isoDate}>
            {formattedDate}
          </time>
          {formattedUpdatedDate && (
            <>
              <span class="text-gray-300 dark:text-gray-600">•</span>
              <span>
                Bijgewerkt: <time datetime={isoUpdatedDate}>{formattedUpdatedDate}</time>
              </span>
            </>
          )}
        </div>
        <h1
          class="mt-2 text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl"
        >
          {post.data.title}
        </h1>
        {
          post.data.tags && (
            <div class="mt-4 flex flex-wrap gap-2">
              {post.data.tags.map((tag: string) => (
                <span class="rounded-full bg-primary-100 px-3 py-1 text-xs font-medium text-primary-700 dark:bg-primary-900 dark:text-primary-300">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </header>

      <div
        class="prose prose-gray mt-10 max-w-none dark:prose-invert prose-headings:font-bold prose-a:text-primary-600 dark:prose-a:text-primary-400"
      >
        <Content />
      </div>
    </div>
  </article>
</Base>
